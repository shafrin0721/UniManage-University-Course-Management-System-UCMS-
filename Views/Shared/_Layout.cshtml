@{
    var title = ViewData["Title"] != null ? ViewData["Title"].ToString() : "UniManage";
    var userId = Session["UserId"];
    var fullName = Session["FullName"] != null ? Session["FullName"].ToString() : "";
    var role = Session["Role"] != null ? Session["Role"].ToString() : "";
    var userDisplay = fullName + " (" + role + ")";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@title - UniManage</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">UniManage</a>
            </div>

            <ul class="nav navbar-nav">
                @if (role == "Administrator")
                {
                    <li>@Html.ActionLink("Dashboard", "Dashboard", "Admin")</li>
                    <li>@Html.ActionLink("Courses", "Index", "Courses")</li>
                    <li>@Html.ActionLink("Reports", "Index", "Reports")</li>
                    <li>@Html.ActionLink("Messages", "Inbox", "Messages")</li>
                }
                else if (role == "Lecturer")
                {
                    <li>@Html.ActionLink("Dashboard", "Dashboard", "Lecturer")</li>
                    <li>@Html.ActionLink("Assignments", "Index", "Assignments")</li>
                    <li>@Html.ActionLink("Reports", "Index", "Reports")</li>
                    <li>@Html.ActionLink("Messages", "Inbox", "Messages")</li>
                }
                else if (role == "Student")
                {
                    <li>@Html.ActionLink("Dashboard", "Dashboard", "Student")</li>
                    <li>@Html.ActionLink("Browse Courses", "Browse", "Enrollment")</li>
                    <li>@Html.ActionLink("My Courses", "MyCourses", "Enrollment")</li>
                    <li>@Html.ActionLink("Assignments", "Index", "Assignments")</li>
                    <li>@Html.ActionLink("Messages", "Inbox", "Messages")</li>
                }
            </ul>

            <ul class="nav navbar-nav navbar-right">
                @if (userId == null)
                {
                    <li>@Html.ActionLink("Register", "Register", "Account")</li>
                    <li>@Html.ActionLink("Login", "Login", "Account")</li>
                }
                else
                {
                    <li><a href="#">@userDisplay</a></li>
                    <li>@Html.ActionLink("Logout", "Logout", "Account")</li>
                }
            </ul>
        </div>
    </nav>

    <div class="container body-content" style="margin-top:70px;">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - UniManage</p>
        </footer>
    </div>

    <script>
        (function () {
            var script = document.createElement('script');
            script.src = '/Scripts/jquery-3.6.0.min.js';
            script.onload = function () { };
            script.onerror = function () {
                var fallback = document.createElement('script');
                fallback.src = '/Scripts/jquery-3.4.1.min.js';
                document.head.appendChild(fallback);
            };
            document.head.appendChild(script);
        })();
    </script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>