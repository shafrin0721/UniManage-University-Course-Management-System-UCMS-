@model UniManage.Models.LecturerDashboardViewModel
@{
    ViewBag.Title = "Lecturer Dashboard";
}

<h2>Welcome, @Model.Name 👋</h2>
<p class="text-muted">Lecturer Dashboard — manage your courses, assignments and student submissions.</p>

{{--- Quick Stats Row ---}}
<div class="row" style="margin-bottom:20px;">
    <div class="col-md-3">
        <div class="panel panel-primary text-center">
            <div class="panel-heading">My Courses</div>
            <div class="panel-body"><h3>@Model.Courses.Count</h3></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="panel panel-warning text-center">
            <div class="panel-heading">Total Submissions</div>
            <div class="panel-body"><h3>@Model.RecentSubmissions.Count</h3></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="panel panel-danger text-center">
            <div class="panel-heading">Pending Grading</div>
            <div class="panel-body"><h3>@Model.RecentSubmissions.Count(s => s.Grade == null)</h3></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="panel panel-success text-center">
            <div class="panel-heading">Graded</div>
            <div class="panel-body"><h3>@Model.RecentSubmissions.Count(s => s.Grade != null)</h3></div>
        </div>
    </div>
</div>

{{--- Quick Links ---}}
<div style="margin-bottom:20px;">
    <a href="@Url.Action("Create","Assignments")" class="btn btn-primary">+ Create Assignment</a>
    <a href="@Url.Action("Index","Assignments")" class="btn btn-default">View All Assignments</a>
    <a href="@Url.Action("Index","Reports")" class="btn btn-default">View Reports</a>
    <a href="@Url.Action("Inbox","Messages")" class="btn btn-default">Messages</a>
</div>

<div class="row">
    {{--- Courses Table ---}}
    <div class="col-md-6">
        <div class="panel panel-default">
            <div class="panel-heading"><strong>My Courses</strong></div>
            <div class="panel-body">
                @if (!Model.Courses.Any())
                {
                    <p class="text-muted">No courses assigned yet.</p>
                }
                else
                {
                    <table class="table table-bordered table-striped">
                        <tr>
                            <th>Code</th>
                            <th>Title</th>
                            <th>Enrollment Limit</th>
                        </tr>
                        @foreach (var course in Model.Courses)
                        {
                            <tr>
                                <td>@course.CourseCode</td>
                                <td>@course.Title</td>
                                <td>@course.EnrollmentLimit</td>
                            </tr>
                        }
                    </table>
                }
            </div>
        </div>
    </div>

    {{--- Recent Submissions Table ---}}
    <div class="col-md-6">
        <div class="panel panel-default">
            <div class="panel-heading"><strong>Recent Submissions</strong></div>
            <div class="panel-body">
                @if (!Model.RecentSubmissions.Any())
                {
                    <p class="text-muted">No submissions yet.</p>
                }
                else
                {
                    <table class="table table-bordered table-striped">
                        <tr>
                            <th>Student</th>
                            <th>Assignment</th>
                            <th>Submitted</th>
                            <th>Grade</th>
                            <th>Action</th>
                        </tr>
                        @foreach (var item in Model.RecentSubmissions)
                        {
                            <tr>
                                <td>@(item.Student != null ? item.Student.FullName : "Unknown")</td>
                                <td>@(item.Assignment != null ? item.Assignment.Title : "N/A")</td>
                                <td>@item.SubmittedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @if (item.Grade.HasValue)
                                    {
                                        <span class="label label-success">@item.Grade.Value.ToString("0.0")</span>
                                    }
                                    else
                                    {
                                        <span class="label label-danger">Pending</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-xs btn-warning" href="@Url.Action("Grade","Assignments", new { id = item.Id })">Grade</a>
                                </td>
                            </tr>
                        }
                    </table>
                }
            </div>
        </div>
    </div>
</div>