@model IEnumerable<UniManage.Models.Course>
@{
    ViewBag.Title = "Browse Courses";
}
<h2>Browse Courses</h2>
@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}
<table class="table table-bordered">
    <tr><th>Code</th><th>Title</th><th>Description</th><th>Limit</th><th>Action</th></tr>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.CourseCode</td>
            <td>@course.Title</td>
            <td>@course.Description</td>
            <td>@course.EnrollmentLimit</td>
            <td>
                @using (Html.BeginForm("Enroll", "Enrollment", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@course.Id" />
                    <button class="btn btn-xs btn-success" type="submit">Enroll</button>
                }
            </td>
        </tr>
    }
</table>
