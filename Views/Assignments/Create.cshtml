@model UniManage.Models.Assignment
@{
    ViewBag.Title = "Create Assignment";
}
<h2>Create Assignment</h2>
<div class="panel-soft" style="max-width:800px;">
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label>Course</label>
        @Html.DropDownList("CourseId", null, "-- Select Course --", new { @class = "form-control" })
    </div>
    <div class="form-group">@Html.LabelFor(m => m.Title) @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })</div>
    <div class="form-group">@Html.LabelFor(m => m.Instructions) @Html.TextAreaFor(m => m.Instructions, new { @class = "form-control", rows = 5 })</div>
    <div class="form-group">@Html.LabelFor(m => m.Deadline) @Html.TextBoxFor(m => m.Deadline, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })</div>
    <button type="submit" class="btn btn-primary">Save Assignment</button>
}
</div>
