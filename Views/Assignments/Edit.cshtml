@model UniManage.Models.Assignment
@{
    ViewBag.Title = "Edit Assignment";
}

<h2>Edit Assignment</h2>

<div class="panel-soft" style="max-width:800px;">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="form-group">
            <label>Course</label>
            @Html.DropDownList("CourseId", null, "-- Select Course --", new { @class = "form-control" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Title)
            @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Instructions)
            @Html.TextAreaFor(m => m.Instructions, new { @class = "form-control", rows = 5 })
        </div>
        <div class="form-group">
            @Html.LabelFor(m => m.Deadline)
            @Html.TextBoxFor(m => m.Deadline, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
        </div>

        <button type="submit" class="btn btn-primary">Update Assignment</button>
        <a href="@Url.Action("Index")" class="btn btn-default">Cancel</a>
    }
</div>