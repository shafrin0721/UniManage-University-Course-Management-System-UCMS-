@model UniManage.Models.Assignment
@{
    ViewBag.Title = "Delete Assignment";
}

<h2>Delete Assignment</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this assignment? This cannot be undone.
</div>

<div class="panel panel-default">
    <div class="panel-body">
        <p><strong>Title:</strong> @Model.Title</p>
        <p><strong>Course:</strong> @(Model.Course != null ? Model.Course.Title : "N/A")</p>
        <p><strong>Deadline:</strong> @Model.Deadline.ToString("yyyy-MM-dd HH:mm")</p>
        <p><strong>Instructions:</strong> @Model.Instructions</p>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a href="@Url.Action("Index")" class="btn btn-default">Cancel</a>
}