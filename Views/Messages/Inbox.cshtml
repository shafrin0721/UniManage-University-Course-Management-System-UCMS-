@model IEnumerable<UniManage.Models.Message>
@{
    ViewBag.Title = "Inbox";
    var allUsers = (System.Collections.Generic.Dictionary<int, string>)ViewBag.UserNames;
}

<h2>📥 Inbox</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div style="margin-bottom:15px;">
    <a class="btn btn-primary" href="@Url.Action("Compose")">✉ Compose Message</a>
    <a class="btn btn-default" href="@Url.Action("Sent")">📤 Sent Messages</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Your inbox is empty.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>From</th>
                <th>Subject</th>
                <th>Message</th>
                <th>Sent At</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsRead ? "" : "warning")">
                    <td>
                        @(ViewBag.UserNames != null && ((System.Collections.Generic.Dictionary<int,string>)ViewBag.UserNames).ContainsKey(item.FromUserId)
                            ? ((System.Collections.Generic.Dictionary<int,string>)ViewBag.UserNames)[item.FromUserId]
                            : "User #" + item.FromUserId)
                    </td>
                    <td><strong>@item.Subject</strong></td>
                    <td>@item.Body</td>
                    <td>@item.SentAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        @if (item.IsRead)
                        {
                            <span class="label label-default">Read</span>
                        }
                        else
                        {
                            <span class="label label-warning">Unread</span>
                        }
                    </td>
                    <td>
                        @if (!item.IsRead)
                        {
                            <a class="btn btn-xs btn-success" href="@Url.Action("MarkAsRead", new { id = item.Id })">Mark as Read</a>
                        }
                        <a class="btn btn-xs btn-primary" href="@Url.Action("Compose", new { replyToUserId = item.FromUserId, replySubject = "RE: " + item.Subject })">Reply</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}