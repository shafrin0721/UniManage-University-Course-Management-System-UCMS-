@model UniManage.Models.Message
@{
    ViewBag.Title = "Compose";
}
<h2>Compose Message</h2>
<div class="panel-soft" style="max-width:800px;">
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label>To</label>
        @Html.DropDownList("ToUserId", null, "-- Select Recipient --", new { @class = "form-control" })
    </div>
    <div class="form-group">@Html.LabelFor(m => m.Subject) @Html.TextBoxFor(m => m.Subject, new { @class = "form-control" })</div>
    <div class="form-group">@Html.LabelFor(m => m.Body) @Html.TextAreaFor(m => m.Body, new { @class = "form-control", rows = 6 })</div>
    <button type="submit" class="btn btn-success">Send</button>
}
</div>
